generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AdminLevel {
  OWNER
  COUNTRY_ADMIN
  ADMIN_L1
  ADMIN_L2
  ADMIN_L3
  CUSTOMER_SUPPORT
}

enum FriendStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

enum FamilyRole {
  OWNER
  CO_OWNER
  ELDER
  MEMBER
}

enum GuideStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum CashoutStatus {
  PENDING_CLEARANCE
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PROCESSING
  COMPLETED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model User {
  id            String   @id @default(cuid())
  username      String   @unique
  email         String   @unique
  password_hash String
  avatar_url    String?
  gender        Gender   @default(OTHER)
  date_of_birth DateTime?
  level         Int      @default(1)
  xp            Int      @default(0)
  vip_tier      Int      @default(0)
  coins         Int      @default(0)
  diamonds      Int      @default(0)
  is_online     Boolean  @default(false)
  is_banned     Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  owned_rooms      Room[]            @relation("RoomOwner")
  room_seats       RoomSeat[]
  sent_messages    Message[]         @relation("MessageSender")
  received_messages Message[]        @relation("MessageReceiver")
  friends_as_user  Friend[]          @relation("UserFriends")
  friends_as_friend Friend[]         @relation("FriendOf")
  owned_family     Family?           @relation("FamilyOwner")
  family_member    FamilyMember?
  cp_partners_1    CpPartnership[]   @relation("CpPartner1")
  cp_partners_2    CpPartnership[]   @relation("CpPartner2")
  medals           UserMedal[]
  game_sessions    GameSession[]
  admin_profile    Admin?
  guide_app        GuideApplication?
  cashout_requests CashoutRequest[]
  tickets          SupportTicket[]
  ticket_messages  TicketMessage[]
  gift_sent        GiftTransaction[] @relation("GiftSender")
  gift_received    GiftTransaction[] @relation("GiftReceiver")
  wallet_txs       WalletTransaction[]

  @@map("users")
}

model Room {
  id             String   @id @default(cuid())
  owner_id       String
  name           String
  type           String
  description    String?
  background_url String?
  is_locked      Boolean  @default(false)
  password       String?
  max_seats      Int      @default(10)
  listener_count Int      @default(0)
  is_permanent   Boolean  @default(false)
  is_official    Boolean  @default(false)
  created_at     DateTime @default(now())

  owner        User              @relation("RoomOwner", fields: [owner_id], references: [id])
  seats        RoomSeat[]
  messages     Message[]
  gifts        GiftTransaction[]

  @@map("rooms")
}

model RoomSeat {
  id          String   @id @default(cuid())
  room_id     String
  user_id     String?
  seat_number Int
  is_muted    Boolean  @default(false)
  joined_at   DateTime @default(now())

  room Room  @relation(fields: [room_id], references: [id])
  user User? @relation(fields: [user_id], references: [id])

  @@unique([room_id, seat_number])
  @@map("room_seats")
}

model Message {
  id              String   @id @default(cuid())
  sender_id       String
  receiver_id     String?
  room_id         String?
  content         String
  type            String   @default("text")
  is_read         Boolean  @default(false)
  created_at      DateTime @default(now())

  sender   User  @relation("MessageSender", fields: [sender_id], references: [id])
  receiver User? @relation("MessageReceiver", fields: [receiver_id], references: [id])
  room     Room? @relation(fields: [room_id], references: [id])

  @@map("messages")
}

model Conversation {
  id           String   @id @default(cuid())
  user1_id     String
  user2_id     String
  last_message String?
  updated_at   DateTime @updatedAt

  @@unique([user1_id, user2_id])
  @@map("conversations")
}

model Gift {
  id             String   @id @default(cuid())
  name           String
  price_diamonds Int
  animation_url  String
  category       String
  is_active      Boolean  @default(true)

  transactions GiftTransaction[]

  @@map("gifts")
}

model GiftTransaction {
  id             String   @id @default(cuid())
  sender_id      String
  receiver_id    String
  room_id        String?
  gift_id        String
  quantity       Int      @default(1)
  total_diamonds Int
  created_at     DateTime @default(now())

  sender   User  @relation("GiftSender", fields: [sender_id], references: [id])
  receiver User  @relation("GiftReceiver", fields: [receiver_id], references: [id])
  room     Room? @relation(fields: [room_id], references: [id])
  gift     Gift  @relation(fields: [gift_id], references: [id])

  @@map("gift_transactions")
}

model WalletTransaction {
  id         String   @id @default(cuid())
  user_id    String
  type       String
  amount     Int
  currency   String
  status     String
  reference  String?
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@map("wallet_transactions")
}

model Friend {
  id         String       @id @default(cuid())
  user_id    String
  friend_id  String
  status     FriendStatus @default(PENDING)
  created_at DateTime     @default(now())

  user   User @relation("UserFriends", fields: [user_id], references: [id])
  friend User @relation("FriendOf", fields: [friend_id], references: [id])

  @@unique([user_id, friend_id])
  @@map("friends")
}

model Family {
  id             String   @id @default(cuid())
  name           String   @unique
  owner_id       String   @unique
  level          Int      @default(1)
  total_diamonds Int      @default(0)
  created_at     DateTime @default(now())

  owner   User           @relation("FamilyOwner", fields: [owner_id], references: [id])
  members FamilyMember[]

  @@map("family")
}

model FamilyMember {
  id        String     @id @default(cuid())
  family_id String
  user_id   String     @unique
  role      FamilyRole @default(MEMBER)
  joined_at DateTime   @default(now())

  family Family @relation(fields: [family_id], references: [id])
  user   User   @relation(fields: [user_id], references: [id])

  @@map("family_members")
}

model CpPartnership {
  id         String   @id @default(cuid())
  user1_id   String
  user2_id   String
  started_at DateTime @default(now())

  user1 User @relation("CpPartner1", fields: [user1_id], references: [id])
  user2 User @relation("CpPartner2", fields: [user2_id], references: [id])

  @@unique([user1_id, user2_id])
  @@map("cp_partnerships")
}

model Medal {
  id          String   @id @default(cuid())
  name        String
  type        String
  requirement String
  icon_url    String
  is_active   Boolean  @default(true)

  users UserMedal[]

  @@map("medals")
}

model UserMedal {
  id         String   @id @default(cuid())
  user_id    String
  medal_id   String
  equipped   Boolean  @default(false)
  earned_at  DateTime @default(now())

  user  User  @relation(fields: [user_id], references: [id])
  medal Medal @relation(fields: [medal_id], references: [id])

  @@unique([user_id, medal_id])
  @@map("user_medals")
}

model Event {
  id         String   @id @default(cuid())
  title      String
  type       String
  banner_url String
  start_date DateTime
  end_date   DateTime
  config     Json
  is_active  Boolean  @default(true)

  @@map("events")
}

model GameSession {
  id                String   @id @default(cuid())
  user_id           String
  game_type         String
  bet_diamonds      Int
  result            String
  winnings_diamonds Int      @default(0)
  created_at        DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@map("game_sessions")
}

model Jackpot {
  id             String    @id @default(cuid())
  game_type      String    @unique
  current_amount Int       @default(0)
  last_won_at    DateTime?
  last_winner_id String?

  @@map("jackpots")
}

model Admin {
  id          String     @id @default(cuid())
  user_id     String     @unique
  email       String     @unique
  name        String
  admin_level AdminLevel
  country     String?
  reports_to  String?
  is_active   Boolean    @default(true)
  assigned_at DateTime   @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@map("admins")
}

model GuideApplication {
  id               String      @id @default(cuid())
  user_id          String      @unique
  languages        String[]
  experience       String?
  motivation       String?
  available_hours  String?
  status           GuideStatus @default(PENDING)
  applied_at       DateTime    @default(now())
  reviewed_at      DateTime?
  reviewed_by      String?
  rejection_reason String?

  user User @relation(fields: [user_id], references: [id])

  @@map("guide_applications")
}

model CashoutRequest {
  id               String        @id @default(cuid())
  user_id          String
  amount_usd       Float
  diamonds_used    Int
  status           CashoutStatus @default(PENDING_CLEARANCE)
  payment_method   String
  payment_details  Json
  requested_at     DateTime      @default(now())
  clearance_date   DateTime
  approved_by      String?
  approved_at      DateTime?
  rejection_reason String?

  user User @relation(fields: [user_id], references: [id])

  @@map("cashout_requests")
}

model SupportTicket {
  id         String       @id @default(cuid())
  user_id    String
  subject    String
  status     TicketStatus @default(OPEN)
  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt

  user     User            @relation(fields: [user_id], references: [id])
  messages TicketMessage[]

  @@map("support_tickets")
}

model TicketMessage {
  id         String   @id @default(cuid())
  ticket_id  String
  sender_id  String
  content    String
  created_at DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticket_id], references: [id])
  sender User          @relation(fields: [sender_id], references: [id])

  @@map("ticket_messages")
}
